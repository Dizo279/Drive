<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/apple_light_gray">

    <!-- Header + Empty Trash button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:gravity="center_vertical"
        android:background="@color/apple_white"
        android:elevation="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thùng rác"
            android:textColor="@color/apple_black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_empty_trash"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Dọn sạch"
            android:textSize="13sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:strokeColor="@color/apple_red"
            android:textColor="@color/apple_red"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <!-- Hint swipe -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="← Vuốt phải để khôi phục  •  Vuốt trái để xóa vĩnh viễn →"
        android:textColor="@color/apple_gray"
        android:textSize="11sp"
        android:background="@color/apple_white"
        android:paddingBottom="6dp" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/apple_divider" />

    <!-- List -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_trash"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_trash"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/layout_empty_trash"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗑️" android:textSize="72sp" />
                <TextView android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/empty_trash"
                    android:textColor="@color/apple_gray"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
