<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom Sheet: Chia sẻ file qua email hoặc public link -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/apple_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            android:background="#DDDDDD" />

        <!-- Tiêu đề -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:text="Chia sẻ file"
            android:textColor="@color/apple_black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Tên file -->
        <TextView
            android:id="@+id/tv_share_file_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="filename.txt"
            android:textColor="@color/apple_gray"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Section: Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:text="✉️  Chia sẻ qua Email"
            android:textColor="@color/apple_black"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <!-- Email input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_share_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email người nhận (cách nhau bởi dấu phẩy)"
            style="@style/Widget.FileManager.TextInputLayout"
            android:layout_marginHorizontal="24dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_share_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:maxLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Hết hạn sau -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="Hết hạn sau:"
            android:textColor="@color/apple_black"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggle_expiry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="16dp"
            app:selectionRequired="true"
            app:singleSelection="true">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_expire_7"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="7 ngày"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_expire_30"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="30 ngày"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_expire_never"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Không giới hạn"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="8dp" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Nút Chia sẻ qua email -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_email"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="24dp"
            android:text="Chia sẻ qua Email"
            android:textSize="15sp"
            style="@style/Widget.FileManager.Button.Primary" />

        <!-- Divider HOẶC -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="24dp"
            android:layout_marginVertical="16dp">

            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/apple_divider"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="  HOẶC  " android:textColor="@color/apple_gray" android:textSize="12sp"/>
            <View android:layout_width="0dp" android:layout_height="1dp"
                android:layout_weight="1" android:background="@color/apple_divider"/>
        </LinearLayout>

        <!-- Nút Tạo Public Link -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_public_link"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="24dp"
            android:text="🌐  Tạo Public Link"
            android:textSize="15sp"
            style="@style/Widget.FileManager.Button.Outlined" />

        <!-- Kết quả: Hiển thị link đã tạo -->
        <LinearLayout
            android:id="@+id/layout_share_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="16dp"
            android:background="@color/apple_blue_light"
            android:padding="14dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_share_result_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Đã tạo link chia sẻ:"
                android:textColor="@color/apple_black"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_share_result_link"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="https://..."
                android:textColor="@color/apple_blue"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:autoLink="all" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_copy_link"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:text="📋  Sao chép link"
                android:textSize="13sp"
                style="@style/Widget.FileManager.Button.Primary" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
