<?xml version="1.0" encoding="utf-8"?>
<!--
    Cho phép HTTP cleartext traffic đến máy chủ local (backend Spring Boot).
    CHỈ dùng trong development. Không dùng trong production.
    - 10.0.2.2: IP của máy host khi chạy trên Android Emulator
    - 192.168.x.x: IP LAN của máy khi test trên thiết bị thật
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android Emulator -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Thiết bị thật - thay bằng IP LAN của máy bạn -->
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
