<?xml version="1.0" encoding="utf-8"?>
<!--
    Cho phép HTTP cleartext traffic đến máy chủ local (backend Spring Boot).
    CHỈ dùng trong development. Không dùng trong production.
    - 10.0.2.2: IP của máy host khi chạy trên Android Emulator
    - 192.168.x.x: IP LAN của máy khi test trên thiết bị thật
-->
<network-security-config>
    <!-- Development: cho phép HTTP tới backend local (emulator + LAN) -->
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
