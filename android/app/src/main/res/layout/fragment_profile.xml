<?xml version="1.0" encoding="utf-8"?>
<!--
    Profile Screen — Màn hình Hồ sơ cá nhân
    Gồm: Avatar + tên, Storage quota, Thông tin tài khoản, Hành động
    Bổ sung: Chọn avatar, chỉnh sửa profile, đổi mật khẩu
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/apple_light_gray"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- === Header Avatar === -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_gradient_blue">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Avatar container (hỗ trợ cả chữ cái và ảnh) -->
                <FrameLayout
                    android:id="@+id/layout_avatar"
                    android:layout_width="84dp"
                    android:layout_height="84dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:alpha="0.9"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <!-- Chữ cái đầu (hiện khi chưa có avatar) -->
                    <TextView
                        android:id="@+id/tv_avatar_letter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="U"
                        android:textColor="#FFFFFF"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <!-- Ảnh avatar tròn (hiện khi đã có avatar URL) -->
                    <ImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:clipToOutline="true"
                        android:visibility="gone" />

                    <!-- Icon camera overlay -->
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="bottom|end"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="@drawable/bg_avatar_circle"
                        android:padding="4dp"
                        android:alpha="0.85" />
                </FrameLayout>

                <!-- Họ tên -->
                <TextView
                    android:id="@+id/tv_full_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Người dùng"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />

                <!-- Email -->
                <TextView
                    android:id="@+id/tv_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="email@example.com"
                    android:textColor="#CCffffff"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

                <!-- Badge PREMIUM / ADMIN -->
                <TextView
                    android:id="@+id/tv_tier_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FREE"
                    android:textColor="@color/apple_blue"
                    android:background="#FFFFFFdd"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="3dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- === Card: Storage Quota === -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-20dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/apple_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Tiêu đề -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="💾  Dung lượng"
                        android:textColor="@color/apple_black"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_quota_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/apple_blue"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Progress bar -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_quota"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="0"
                    android:max="100"
                    android:indeterminate="false"
                    app:indicatorColor="@color/apple_blue"
                    app:trackColor="@color/apple_blue_light"
                    app:trackCornerRadius="4dp" />

                <!-- Used / Max -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/tv_quota_used"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0 MB đã dùng"
                        android:textColor="@color/apple_gray"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_quota_max"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/ 1 GB"
                        android:textColor="@color/apple_gray"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Nâng cấp Premium (ẩn nếu đã Premium) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_upgrade_premium"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="16dp"
                    android:text="⭐  Nâng cấp lên Premium"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    style="@style/Widget.FileManager.Button.Primary"
                    android:visibility="visible" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- === Card: Thông tin tài khoản === -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/apple_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤  Thông tin tài khoản"
                    android:textColor="@color/apple_black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Loading -->
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progress_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    android:visibility="visible"
                    app:indicatorColor="@color/apple_blue"
                    app:trackColor="@color/apple_blue_light" />

                <!-- Username row -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    android:id="@+id/layout_profile_info">

                    <TextView android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Tên đăng nhập"
                        android:textColor="@color/apple_gray"
                        android:textSize="13sp" />
                    <TextView android:id="@+id/tv_info_username"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="@color/apple_black"
                        android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <View android:id="@+id/divider_info" android:layout_width="match_parent"
                    android:layout_height="1dp" android:background="@color/apple_divider"
                    android:visibility="gone"/>

                <!-- Email row -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:id="@+id/layout_email_info"
                    android:visibility="gone">

                    <TextView android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="@color/apple_gray"
                        android:textSize="13sp" />
                    <TextView android:id="@+id/tv_info_email"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="@color/apple_black"
                        android:textSize="14sp" />
                </LinearLayout>

                <View android:id="@+id/divider_email" android:layout_width="match_parent"
                    android:layout_height="1dp" android:background="@color/apple_divider"
                    android:visibility="gone"/>

                <!-- Role row -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:id="@+id/layout_role_info"
                    android:visibility="gone">

                    <TextView android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:text="Vai trò"
                        android:textColor="@color/apple_gray"
                        android:textSize="13sp" />
                    <TextView android:id="@+id/tv_info_role"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="—"
                        android:textColor="@color/apple_black"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- === Card: Hành động === -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/apple_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="8dp">

                <!-- Chỉnh sửa thông tin cá nhân -->
                <LinearLayout
                    android:id="@+id/action_edit_profile"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✏️" android:textSize="20sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chỉnh sửa thông tin"
                        android:textColor="@color/apple_black" android:textSize="15sp"
                        android:layout_marginStart="12dp" />
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›" android:textColor="@color/apple_gray" android:textSize="20sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/apple_divider"
                    android:layout_marginHorizontal="20dp"/>

                <!-- Đổi mật khẩu -->
                <LinearLayout
                    android:id="@+id/action_change_password"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔑" android:textSize="20sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Đổi mật khẩu"
                        android:textColor="@color/apple_black" android:textSize="15sp"
                        android:layout_marginStart="12dp" />
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›" android:textColor="@color/apple_gray" android:textSize="20sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/apple_divider"
                    android:layout_marginHorizontal="20dp"/>

                <!-- Đăng xuất -->
                <LinearLayout
                    android:id="@+id/action_logout"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="20dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🚪" android:textSize="20sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/btn_logout"
                        android:textColor="@color/apple_red" android:textSize="15sp"
                        android:textStyle="bold" android:layout_marginStart="12dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- App version -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="File Manager v1.0.0"
            android:textColor="@color/apple_gray"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
