<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom Sheet: Tùy chọn hành động trên file/folder -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp"
    android:paddingBottom="24dp"
    android:background="@color/apple_white">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="#DDDDDD"
        android:layout_marginTop="8dp"/>

    <!-- Tên file (tiêu đề) -->
    <TextView
        android:id="@+id/tv_bs_file_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="12dp"
        android:text="filename.txt"
        android:textColor="@color/apple_gray"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center" />

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/apple_divider" android:layout_marginBottom="8dp"/>

    <!-- Tải xuống -->
    <LinearLayout
        android:id="@+id/action_download"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="?attr/selectableItemBackground">

        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="⬇️" android:textSize="20sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/action_download"
            android:textColor="@color/apple_black" android:textSize="15sp"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Chia sẻ -->
    <LinearLayout
        android:id="@+id/action_share"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="?attr/selectableItemBackground">

        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="🔗" android:textSize="20sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/action_share"
            android:textColor="@color/apple_black" android:textSize="15sp"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Đổi tên (TODO Phase 2 nâng cao) -->
    <LinearLayout
        android:id="@+id/action_rename"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="?attr/selectableItemBackground">

        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="✏️" android:textSize="20sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/action_rename"
            android:textColor="@color/apple_black" android:textSize="15sp"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/apple_divider" android:layout_marginVertical="4dp"/>

    <!-- Xóa (màu đỏ) -->
    <LinearLayout
        android:id="@+id/action_delete"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="?attr/selectableItemBackground">

        <TextView android:layout_width="28dp" android:layout_height="wrap_content"
            android:text="🗑️" android:textSize="20sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/action_delete"
            android:textColor="@color/apple_red" android:textSize="15sp"
            android:textStyle="bold" android:layout_marginStart="12dp" />
    </LinearLayout>

</LinearLayout>
